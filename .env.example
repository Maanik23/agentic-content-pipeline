PIPELINE_LLM_PROVIDER=openai
PIPELINE_LLM_MODEL=gpt-4o
PIPELINE_LLM_API_KEY=sk-your-key-here
PIPELINE_REDIS_URL=redis://localhost:6379/0
PIPELINE_CACHE_TTL=3600
PIPELINE_CACHE_SIMILARITY_THRESHOLD=0.92
PIPELINE_MAX_REVISIONS=3
PIPELINE_REVIEW_SCORE_THRESHOLD=7.0
PIPELINE_ENABLE_CACHE=true
PIPELINE_ENABLE_HITL=false
